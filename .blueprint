models:
    AfiliacionIva: { abreviacion: 'string nullable', nombre: string }
    Categoria: { nombre: 'string:100', descripcion: text }
    Certificador: { nit: string, nombre: string, estado: 'tinyinteger default:1', created_by: 'biginteger unsigned nullable', updated_by: 'biginteger unsigned nullable', deleted_by: 'biginteger unsigned nullable' }
    Cliente: { tipo_entidad: 'tinyinteger unsigned default:1', codigo_interno: 'string nullable', id_afiliacion_iva: 'biginteger unsigned', cod_establecimiento: 'string nullable', correo: 'string nullable', nit: 'string nullable', telefono: 'string nullable', nombre_comercial: 'string nullable', nombre: string, direccion: 'string nullable', codigo_postal: 'string nullable', id_municipio: 'biginteger unsigned', estado: 'tinyinteger unsigned default:1', created_by: 'tinyinteger unsigned nullable', updated_by: 'tinyinteger unsigned nullable', deleted_by: 'tinyinteger unsigned nullable' }
    Comprobante: { tipo_comprobante: 'string:50', estado: 'tinyinteger default:1' }
    Departamento: { codigo: 'string nullable', nombre: string, pais_id: 'biginteger unsigned' }
    Documento: { tipo_documento: 'string:30', descripcion: 'string:100', estado: 'tinyinteger default:1' }
    Escenario: { cod_escenario: integer, id_frases: 'biginteger unsigned', escenario: string, efecto: string, nombre: string, tipo_dte: string, frase_automatica: string }
    Frase: { nombre: string, descripcion: text }
    ImpuestoTipo: { descripcion: string, observaciones: 'text nullable' }
    ImpuestoUnidadGravable: { codigo: integer, nombre: 'string:500', nombre_corto: 'string:500', tasa_monto: 'decimal:8,2', id_cvimpuestostipo: 'biginteger unsigned' }
    InventarioStock: { id_producto: 'biginteger unsigned', id_sucursal: 'biginteger unsigned', cantidad_actual: 'decimal:10,2', stock_minimo: 'decimal:10,2 nullable', ubicacion: 'string:50 nullable', estado: 'tinyinteger unsigned default:1', created_by: 'biginteger unsigned nullable', updated_by: 'biginteger unsigned nullable', deleted_by: 'biginteger unsigned nullable' }
    Moneda: { codigo: string, nombre: string, simbolo: string }
    MovimientoInventario: { fecha: date, id_sucursal: 'biginteger unsigned', tipo_movimiento: "enum:'ENTRADA','SALIDA','AJUSTE','TRASLADO'", numero_documento: 'string:50 nullable', observaciones: 'text nullable', sucursal_destino: 'biginteger unsigned nullable', estado: 'tinyinteger unsigned default:1', created_by: 'biginteger unsigned nullable', updated_by: 'biginteger unsigned nullable', deleted_by: 'biginteger unsigned nullable' }
    MovimientoInventarioDetalle: { id_movimiento: 'biginteger unsigned', id_producto: 'biginteger unsigned', cantidad: 'decimal:10,2', costo_unitario: 'decimal:10,2 nullable' }
    Municipio: { codigo: 'string nullable', nombre: string, departamento_id: 'biginteger unsigned' }
    Pais: { nombre: string, abreviatura: 'string nullable', region_codigo: 'string nullable' }
    Proveedor: { tipo_entidad: 'tinyinteger unsigned default:1', codigo_interno: 'string nullable', id_afiliacion_iva: 'biginteger unsigned nullable default:1', cod_establecimiento: 'string nullable', correo: 'string nullable', nit: 'string nullable', telefono: 'string nullable', nombre_comercial: 'string nullable', nombre: string, direccion: 'string nullable', codigo_postal: 'string nullable', id_municipio: 'biginteger unsigned nullable', estado: 'tinyinteger unsigned default:1', created_by: 'tinyinteger unsigned nullable', updated_by: 'tinyinteger unsigned nullable', deleted_by: 'tinyinteger unsigned nullable' }
    PurchaseInvoice: { tipoComprobante: 'tinyinteger unsigned default:1', id_moneda: 'biginteger unsigned default:1', id_tipoDte: 'biginteger unsigned nullable', id_proveedor: 'biginteger unsigned', fechahora_emision: timestamp, id_certificador: 'biginteger unsigned nullable', no_autorizacion: 'string nullable', serie: 'string nullable', codigo_autorizacion: 'string nullable', fechahora_certificacion: 'timestamp nullable', notes: 'text nullable', estado: 'tinyinteger unsigned default:1', created_by: 'biginteger unsigned nullable', updated_by: 'biginteger unsigned nullable', deleted_by: 'biginteger unsigned nullable' }
    PurchaseInvoiceItem: { id_compra: 'biginteger unsigned', numerolinea: 'integer nullable', tipo: string, cantidad: 'decimal:10,6', producto_id: 'biginteger unsigned', precio_unitario: 'decimal:10,6', precio_parcial: 'decimal:10,6 nullable default:0.000000', descuento: 'decimal:10,6 nullable default:0.000000', otros_descuentos: 'decimal:10,6 nullable default:0.000000', total: 'decimal:10,6 nullable default:0.000000', impuesto: 'decimal:10,6 nullable default:0.000000' }
    Sucursal: { nombre: string, direccion: 'string nullable', telefono: 'string nullable', id_municipio: 'biginteger unsigned', tipo: 'tinyinteger unsigned default:1', estado: 'tinyinteger unsigned default:1', created_by: 'tinyinteger unsigned nullable', updated_by: 'tinyinteger unsigned nullable', deleted_by: 'tinyinteger unsigned nullable' }
    SucursalUsuario: { id_sucursal: 'biginteger unsigned', id_usuario: 'biginteger unsigned', estado: 'tinyinteger unsigned default:1', default: 'tinyinteger unsigned', created_by: 'tinyinteger unsigned nullable', updated_by: 'tinyinteger unsigned nullable', deleted_by: 'tinyinteger unsigned nullable' }
    TipoDte: { nombre: string, codigo: string, descripcion: text }
    User: { nombre1: string, nombre2: 'string nullable', nombre3: 'string nullable', apellido1: string, apellido2: 'string nullable', email: string, email_verified_at: 'timestamp nullable', password: string, remember_token: 'string:100 nullable', estado: 'tinyinteger unsigned default:1', created_by: 'tinyinteger unsigned nullable', updated_by: 'tinyinteger unsigned nullable', deleted_by: 'tinyinteger unsigned nullable' }
    marcas: { nombre: 'string:100', descripcion: text }
    productos: { codigo: 'string:15', nombre: 'string:100', descripcion: text, fecha: date, imagen: 'string nullable', precio_compra: 'decimal:8,2', precio_venta: 'decimal:8,2', precio_mayoreo: 'decimal:8,2', id_marca: 'biginteger unsigned', id_categorias: 'biginteger unsigned', estado: 'tinyinteger unsigned default:1' }
